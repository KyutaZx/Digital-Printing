        {
          "name": "STEP 12 - Staff Lihat Semua Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_staff}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/staff/orders"
            }
          }
        },
        {
          "name": "STEP 13 - Staff Review Desain - Approve (Design ID: 1)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_staff}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"status\": \"approved\",\n  \"notes\": \"Desain sudah oke, resolusi bagus, siap cetak!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/staff/designs/1/review"
            }
          }
        },
        {
          "name": "STEP 14 - Staff Approve Pembayaran (ganti payment ID)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_staff}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/staff/payments/{{payment_id}}/approve"
            }
          }
        },
        {
          "name": "STEP 15 - Staff Mulai Produksi",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_staff}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"notes\": \"Mulai cetak di Mesin Epson A, target selesai hari ini\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/staff/production/{{order_id}}/start"
            }
          }
        },
        {
          "name": "STEP 16 - Staff Selesai Produksi",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_staff}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"notes\": \"Hasil cetak tajam, sudah dilaminasi doff. Siap dijemput!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/staff/production/{{order_id}}/finish"
            }
          }
        },
        {
          "name": "STEP 17 - Customer Konfirmasi Order Selesai",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/orders/{{order_id}}/complete"
            }
          }
        }
      ]
    },
