  "item": [
    {
      "name": "FLOW - Alur Lengkap Customer",
      "description": "Ikuti urutan 1-12 untuk test end-to-end flow",
      "item": [
        {
          "name": "STEP 1 - Customer Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token_customer', res.token);",
                  "  console.log('✅ Token customer tersimpan');",
                  "} else {",
                  "  console.log('❌ Login gagal:', JSON.stringify(res));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"email\": \"customer@gmail.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login"
            }
          }
        },
        {
          "name": "STEP 2 - Lihat Katalog Produk",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products"
            }
          }
        },
        {
          "name": "STEP 3 - Tambah Banner ke Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 2,\n  \"variant_id\": 1,\n  \"notes\": \"Cetak banner ukuran 2x1 meter, bahan outdoor\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/cart"
            }
          }
        },
        {
          "name": "STEP 4 - Tambah Poster ke Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{\n  \"product_id\": 2,\n  \"quantity\": 10,\n  \"variant_id\": 2,\n  \"notes\": \"Poster A3 untuk promosi toko\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/cart"
            }
          }
        },
        {
          "name": "STEP 5 - Lihat Isi Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/cart"
            }
          }
        },
        {
          "name": "STEP 6 - Checkout (Buat Order dari Cart)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.order && res.order.id) {",
                  "  pm.collectionVariables.set('order_id', res.order.id);",
                  "  console.log('✅ Order ID tersimpan:', res.order.id);",
                  "} else if (res.id) {",
                  "  pm.collectionVariables.set('order_id', res.id);",
                  "  console.log('✅ Order ID tersimpan:', res.id);",
                  "} else {",
                  "  console.log('Response:', JSON.stringify(res));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "options": {
                "raw": {
                  "language": "json"
                }
              },
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/checkout"
            }
          }
        },
        {
          "name": "STEP 7 - Lihat Daftar Order Saya",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/orders"
            }
          }
        },
        {
          "name": "STEP 8 - Lihat Detail Order (ganti ID di URL jika perlu)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/orders/{{order_id}}"
            }
          }
        },
        {
          "name": "STEP 9 - Upload Desain (Order Item ID: 1, ganti jika perlu)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Pilih file desain JPG/PNG/PDF"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/orders/items/1/design"
            }
          }
        },
        {
          "name": "STEP 10 - Upload Bukti Pembayaran",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.payment && res.payment.id) {",
                  "  pm.collectionVariables.set('payment_id', res.payment.id);",
                  "  console.log('✅ Payment ID tersimpan:', res.payment.id);",
                  "} else if (res.id) {",
                  "  pm.collectionVariables.set('payment_id', res.id);",
                  "} else {",
                  "  console.log('Response:', JSON.stringify(res));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token_customer}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "order_id",
                  "value": "{{order_id}}",
                  "type": "text"
                },
                {
                  "key": "payment_method_id",
                  "value": "1",
                  "type": "text",
                  "description": "1=BCA, 2=Mandiri, 3=QRIS"
                },
                {
                  "key": "amount",
                  "value": "250000",
                  "type": "text",
                  "description": "2 Banner x50000 + 10 Poster x15000"
                },
                {
                  "key": "transaction_code",
                  "value": "TF-BCA-20260502-001",
                  "type": "text"
                },
                {
                  "key": "payment_proof",
                  "type": "file",
                  "src": "",
                  "description": "Screenshot bukti transfer"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/payments"
            }
          }
        },
        {
          "name": "STEP 11 - Staff Login",
          "event": [
            {
              "listen": "test",
